{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Paginas del generador de sitios modular"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "module": {
      "type": "enumeration",
      "enum": [
        "default",
        "academic",
        "congress",
        "diffusion"
      ],
      "default": "default"
    },
    "blocks": {
      "type": "json"
    },
    "pageSettings": {
      "type": "json"
    }
  }
}
